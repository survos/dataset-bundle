{
    "name": "survos/dataset-bundle",
    "description": "Shared data directory conventions and path utilities for dataset-driven apps (APP_DATA_DIR).",
    "type": "symfony-bundle",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Survos\\DatasetBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\DatasetBundle\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.5",
        "doctrine/dbal": "^4.2",
        "symfony/framework-bundle": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/config": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/filesystem": "^8.1",
        "symfony/console": "^8.1",
        "symfony/ux-twig-component": "^3",
        "survos/data-contracts": "^2.5",
        "survos/lingua-contracts": "^2.5",
        "survos/lingua-core": "^2.5",
        "survos/jsonl-bundle": "^2.5",
        "zenstruck/bytes": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "symfony/yaml": "^8.1",
        "survos/import-bundle": "^2.5",
        "survos/ai-workflow-bundle": "^2.5"
    },
    "suggest": {
        "survos/ai-workflow-bundle": "Wires DatasetIterateRowEvent → Subject creation for AI workflow pipelines"
    },
    "prefer-stable": true,
    "extra": {
        "symfony": {
            "require": "^8.1"
        }
    }
}
