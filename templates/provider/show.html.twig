{% extends 'base.html.twig' %}

{% block title %}Provider: {{ provider.code|upper }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="d-flex align-items-center justify-content-between">
      <div>
        <h1 class="page-title">Provider: {{ provider.code|upper }}</h1>
        {% if provider.label %}
          <div class="text-muted">{{ provider.label }}</div>
        {% endif %}
      </div>
      <div class="d-flex gap-2">
        {% if provider.homepage %}
          <a class="btn btn-outline-secondary btn-sm" href="{{ provider.homepage }}" target="_blank" rel="noopener">Website</a>
        {% endif %}
        <a class="btn btn-outline-primary btn-sm" href="{{ path('meili_insta', {indexName: 'md_' ~ provider.code}) }}" target="_blank">Search</a>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row g-3">
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <div class="row g-3">
              <div class="col-md-8">
                {% if provider.description %}
                  <p class="mb-2 text-muted">{{ provider.description }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title mb-0">Candidates</h3>
          </div>
          <div class="card-body">
            <twig:api_grid
              facets="false"
              :class="candidateClass"
              :apiGetCollectionUrl="candidateApiUrl"
              :filter="{ 'providerCode[]': provider.code }"
              :columns="[
                {name: 'candidateKey'},
                {name: 'sourceId'},
                {name: 'kind'},
                {name: 'label'},
                {name: 'status'},
                {name: 'datasetKey'},
                {name: 'updatedAt'}
              ]"
            />
          </div>
        </div>
      </div>
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title mb-0">Datasets</h3>
          </div>
          <div class="card-body">
            <twig:api_grid
              facets="false"
              :class="datasetClass"
              :apiGetCollectionUrl="datasetApiUrl"
              :columns="[
                {name: 'datasetKey'},
                {name: 'label'},
                {name: 'status'},
                {name: 'objCount'},
                {name: 'normalizedCount'},
                {name: 'lastScanned'}
              ]"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
